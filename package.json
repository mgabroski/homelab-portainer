{
  "name": "homelab-portainer",
  "version": "1.0.0",
  "description": "Portainer CE — Visual Docker management dashboard",
  "private": true,
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:yaml": "yamllint docker-compose.yml",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint": "yarn lint:yaml && yarn lint:md",
    "validate": "yarn format:check && yarn lint"
  },
  "lint-staged": {
    "*.{yml,yaml}": [
      "prettier --write",
      "yamllint"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.2"
  }
}
